      "source": [
        "def calculate_price_included_tax(price:int,tax:int)->int:\n",
        "    # 演習なので端数処理は考えない\n",
        "    return price * ((100 + tax) / 100)\n",
        "\n",
        "price = 110\n",
        "tax = 10\n",
        "print(calculate_price_included_tax(price,tax))"
      ]
    }
